{
  "name": "alitkovsky",
  "version": "0.3.0",
  "engines": {
    "node": "22.x",
    "npm": ">=10.x"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions"
  ],
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "build": "next build",
    "postbuild": "node scripts/strip-polyfills.js",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint --config eslint.config.mjs .",
    "check-unused": "npx depcheck --ignores next,react,react-dom",
    "clean-unused": "npx depcheck --json | jq -r '.dependencies[]' | grep -vE '^(postcss|autoprefixer|tailwindcss|@tailwindcss/.*|next|react|react-dom|eslint.*|prettier.*)$' | xargs npm uninstall"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@next/third-parties": "^16.2.9",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.18.0",
    "mathjs": "^15.2.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "svg-pathdata": "^9.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "vara": "^1.4.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "baseline-browser-mapping": "^2.10.37",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.2.9"
  }
}
